apiVersion: hive.openshift.io/v1
kind: ClusterDeployment
metadata:
  name: {{ bm_cluster_name }}
  annotations:
    open-cluster-management.io/display-name: {{ bm_cluster_display_name | default(bm_cluster_name) }}
  namespace: {{ bm_cluster_name }}
spec:
  baseDomain: {{ bm_base_domain }}
  clusterName: {{ bm_cluster_name }}
  installed: false
  platform:
    agentBareMetal:
      agentSelector:
        matchLabels:
          agentclusterinstalls.extensions.hive.openshift.io/location: {{ bm_cluster_name }}
  clusterInstallRef:
    group: extensions.hive.openshift.io
    kind: AgentClusterInstall
    name: {{ bm_cluster_name }}
    version: v1beta1
  pullSecretRef:
    name: {{ bm_pull_secret_name }}
