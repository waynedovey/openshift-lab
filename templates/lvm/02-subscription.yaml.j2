apiVersion: operators.coreos.com/v1alpha1
kind: Subscription
metadata:
  name: {{ lvm_subscription_name }}
  namespace: {{ lvm_namespace }}
spec:
  channel: {{ lvm_operator_channel }}
  installPlanApproval: {{ lvm_install_plan_approval }}
  name: {{ lvm_operator_package }}
  source: {{ lvm_operator_source }}
  sourceNamespace: {{ lvm_operator_source_namespace }}
