apiVersion: v1
kind: Namespace
metadata:
  name: {{ site_a_policy_namespace }}
---
apiVersion: cluster.open-cluster-management.io/v1beta2
kind: ManagedClusterSetBinding
metadata:
  name: {{ bm_clusterset }}
  namespace: {{ site_a_policy_namespace }}
spec:
  clusterSet: {{ bm_clusterset }}
---
apiVersion: cluster.open-cluster-management.io/v1beta1
kind: Placement
metadata:
  name: {{ site_a_policy_placement_name }}
  namespace: {{ site_a_policy_namespace }}
spec:
{% if site_a_policy_tolerate_unreachable | default(false) | bool %}
  tolerations:
    - key: cluster.open-cluster-management.io/unreachable
      operator: Exists
      effect: NoSelect
    - key: cluster.open-cluster-management.io/unavailable
      operator: Exists
      effect: NoSelect
{% endif %}
  predicates:
    - requiredClusterSelector:
        labelSelector:
          matchLabels:
            {{ site_a_policy_cluster_label_key }}: "{{ site_a_policy_cluster_label_value }}"
---
apiVersion: policy.open-cluster-management.io/v1
kind: PlacementBinding
metadata:
  name: site-a-hcp-prereqs-binding
  namespace: {{ site_a_policy_namespace }}
placementRef:
  apiGroup: cluster.open-cluster-management.io
  kind: Placement
  name: {{ site_a_policy_placement_name }}
subjects:
  - apiGroup: policy.open-cluster-management.io
    kind: Policy
    name: site-a-openshift-virtualization
  - apiGroup: policy.open-cluster-management.io
    kind: Policy
    name: site-a-mce-hcp-hosting
  - apiGroup: policy.open-cluster-management.io
    kind: Policy
    name: site-a-metallb-hcp
  - apiGroup: policy.open-cluster-management.io
    kind: Policy
    name: site-a-ingress-wildcards
{% if site_a_lvm_policy_enabled | default(false) | bool %}
  - apiGroup: policy.open-cluster-management.io
    kind: Policy
    name: site-a-lvm-storage
{% endif %}
---
# Hub-side add-on object. This is intentionally applied to the RHACM hub, not through a policy.
# It lets the central hub discover hosted clusters created by the MCE/HCP stack on Site-A.
apiVersion: addon.open-cluster-management.io/v1alpha1
kind: ManagedClusterAddOn
metadata:
  name: hypershift-addon
  namespace: {{ bm_cluster_name }}
spec:
  installNamespace: open-cluster-management-agent-addon-discovery
