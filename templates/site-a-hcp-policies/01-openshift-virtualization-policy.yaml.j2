apiVersion: policy.open-cluster-management.io/v1
kind: Policy
metadata:
  name: site-a-openshift-virtualization
  namespace: {{ site_a_policy_namespace }}
  annotations:
    policy.open-cluster-management.io/standards: Site-A HCP
    policy.open-cluster-management.io/categories: Virtualization
    policy.open-cluster-management.io/controls: Install OpenShift Virtualization
spec:
  remediationAction: {{ site_a_policy_remediation_action }}
  disabled: false
  policy-templates:
    - objectDefinition:
        apiVersion: policy.open-cluster-management.io/v1
        kind: ConfigurationPolicy
        metadata:
          name: site-a-openshift-virtualization
        spec:
          remediationAction: {{ site_a_policy_remediation_action }}
          severity: medium
          object-templates:
            - complianceType: musthave
              objectDefinition:
                apiVersion: v1
                kind: Namespace
                metadata:
                  name: {{ site_a_virt_namespace }}
            - complianceType: musthave
              objectDefinition:
                apiVersion: operators.coreos.com/v1
                kind: OperatorGroup
                metadata:
                  name: openshift-cnv-group
                  namespace: {{ site_a_virt_namespace }}
                spec:
                  targetNamespaces:
                    - {{ site_a_virt_namespace }}
            - complianceType: musthave
              objectDefinition:
                apiVersion: operators.coreos.com/v1alpha1
                kind: Subscription
                metadata:
                  name: kubevirt-hyperconverged
                  namespace: {{ site_a_virt_namespace }}
                spec:
                  channel: {{ site_a_virt_subscription_channel }}
                  installPlanApproval: {{ site_a_virt_install_plan_approval }}
                  name: kubevirt-hyperconverged
                  source: {{ site_a_virt_operator_source }}
                  sourceNamespace: {{ site_a_virt_operator_source_namespace }}
            - complianceType: musthave
              objectDefinition:
                apiVersion: hco.kubevirt.io/v1beta1
                kind: HyperConverged
                metadata:
                  name: kubevirt-hyperconverged
                  namespace: {{ site_a_virt_namespace }}
                spec: {}
