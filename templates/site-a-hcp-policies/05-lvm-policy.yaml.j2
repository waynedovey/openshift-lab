{% if site_a_lvm_policy_enabled | default(false) | bool %}
apiVersion: policy.open-cluster-management.io/v1
kind: Policy
metadata:
  name: site-a-lvm-storage
  namespace: {{ site_a_policy_namespace }}
  annotations:
    policy.open-cluster-management.io/standards: Site-A HCP
    policy.open-cluster-management.io/categories: Storage
    policy.open-cluster-management.io/controls: Optional LVM storage for HCP etcd and KubeVirt disks
spec:
  remediationAction: {{ site_a_policy_remediation_action }}
  disabled: false
  policy-templates:
    - objectDefinition:
        apiVersion: policy.open-cluster-management.io/v1
        kind: ConfigurationPolicy
        metadata:
          name: site-a-lvm-storage
        spec:
          remediationAction: {{ site_a_policy_remediation_action }}
          severity: medium
          object-templates:
            - complianceType: musthave
              objectDefinition:
                apiVersion: v1
                kind: Namespace
                metadata:
                  name: {{ site_a_lvm_namespace }}
            - complianceType: musthave
              objectDefinition:
                apiVersion: operators.coreos.com/v1
                kind: OperatorGroup
                metadata:
                  name: openshift-storage-operatorgroup
                  namespace: {{ site_a_lvm_namespace }}
            - complianceType: musthave
              objectDefinition:
                apiVersion: operators.coreos.com/v1alpha1
                kind: Subscription
                metadata:
                  name: lvms-operator
                  namespace: {{ site_a_lvm_namespace }}
                spec:
                  channel: {{ site_a_lvm_subscription_channel }}
                  installPlanApproval: {{ site_a_lvm_install_plan_approval }}
                  name: lvms-operator
                  source: {{ site_a_lvm_operator_source }}
                  sourceNamespace: {{ site_a_lvm_operator_source_namespace }}
            - complianceType: musthave
              objectDefinition:
                apiVersion: lvm.topolvm.io/v1alpha1
                kind: LVMCluster
                metadata:
                  name: {{ site_a_lvm_cluster_name }}
                  namespace: {{ site_a_lvm_namespace }}
                spec:
                  storage:
                    deviceClasses:
                      - name: {{ site_a_lvm_device_class_name }}
                        thinPoolConfig:
                          name: thin-pool-1
                          sizePercent: 90
                          overprovisionRatio: 10
{% if site_a_lvm_device_paths | default([]) | length > 0 %}
                        deviceSelector:
                          paths:
{% for d in site_a_lvm_device_paths %}
                            - {{ d }}
{% endfor %}
{% endif %}
{% endif %}
